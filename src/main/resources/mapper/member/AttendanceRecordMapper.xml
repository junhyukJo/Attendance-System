<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.attendance.system.member.mapper.AttendanceRecordMapper">

    <insert id="insert" parameterType="com.attendance.system.member.domain.AttendanceRecord">
        INSERT INTO attendance_records (
            id,
            member_id,
            name,
            birth_date,
            reg_dtm,
            chg_dtm
        ) VALUES (
            #{id},
            #{memberId},
            #{name},
            #{birthDate},
            #{regDtm},
            #{chgDtm}
        )
    </insert>

    <select id="findById" parameterType="string" resultType="com.attendance.system.member.domain.AttendanceRecord">
        SELECT
            id,
            member_id,
            name,
            birth_date,
            reg_dtm,
            chg_dtm
        FROM attendance_records
        WHERE id = #{id}
    </select>

</mapper>
